{
    "python.formatting.provider": "black",
    "java.compile.nullAnalysis.mode": "automatic",
    "python.linting.flake8Enabled": true,
    "colors.enable": true,
    "pyright.disableDiagnostics": true,
    "yaml.schemas": {},
    "coc.preferences.formatOnSaveFiletypes":  ["*"],
    "languageserver": {
      "terraform": {
          "command": "terraform-ls",
          "args": ["serve"],
          "filetypes": [
              "terraform",
              "tf"
          ],
          "initializationOptions": {},
          "settings": {}
      },
      "helm": {
        "command": "helm_ls",
        "args": ["serve"],
        "filetypes": ["helm", "yaml"],
        "rootPatterns": ["Chart.yaml", "Chart.yml", "values.yaml"],
        "initializationOptions": {
          "yamlLanguageServer": {
            "path": "yaml-language-server"
          }
        }
      }
    },
    "yaml.schemas": {
      "kubernetes": "templates/*.yaml"
    },
    "java.configuration.runtimes": [
      {
        "name": "JavaSE-17",
        "path": "${JAVA_17_HOME}",
        "default": true
      },
      {
        "name": "JavaSE-1.8",
        "path": "${JAVA_8_HOME}"
      },
      {
        "name": "JavaSE-11",
        "path": "${JAVA_11_HOME}"
      }
    ]
}
